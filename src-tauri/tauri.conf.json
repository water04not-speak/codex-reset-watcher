{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codex-reset-watcher",
  "version": "0.1.0",
  "identifier": "com.codex-reset-watcher.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "codex-reset-watcher",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "script-src": "'self'",
        "style-src": "'unsafe-inline' 'self'",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "font-src": "'self' data:"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:1420",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' http://localhost:1420",
        "style-src": "'unsafe-inline' 'self' http://localhost:1420",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "font-src": "'self' data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
